{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module":        "commonjs",
    "target":        "ES2020",
    "outDir":        "dist",
    "rootDir":       ".",
    "noEmit":        false,
    "sourceMap":     true,
    "declaration":   false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck":  true
  },
  "include": [
    "backend/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "backend/tests",
    "dist"
  ]
}
