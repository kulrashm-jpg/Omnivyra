# Social Media API Configuration
# Copy this file to .env.local and fill in your actual API credentials

# Base URL for OAuth callbacks
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# LinkedIn API Credentials
# Get these from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Twitter API Credentials  
# Get these from: https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Facebook API Credentials
# Get these from: https://developers.facebook.com/apps/
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# Instagram API Credentials (uses Facebook app)
# Same as Facebook credentials
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret

# Database Configuration (if using real database)
DATABASE_URL=your_database_url

# JWT Secret for session management
JWT_SECRET=your_jwt_secret_key

# Omnivyre API Configuration
OMNIVYRE_BASE_URL=https://omnivyre.example.com























