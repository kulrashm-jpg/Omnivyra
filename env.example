# ─────────────────────────────────────────────────────────────────────────────
# Omnivyra Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# 
# Copy this file to .env.local and fill in your values.
# All values are validated at startup — invalid config will cause failure.
# 
# ⚠️ NEVER commit secrets to version control — use .env.local (git-ignored)
# ⚠️ REDIS_URL format: redis://user:pass@host:port (NOT redis-cli command syntax)
# 

# ─── Runtime Environment ──────────────────────────────────────────────────────
NODE_ENV=production
NEXT_RUNTIME=nodejs    # 'nodejs' or 'edge' (for Vercel Edge Functions)

# ─── Supabase (REQUIRED) ───────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# ─── Redis / Upstash (REQUIRED) ────────────────────────────────────────────────
# 
# ⚠️ IMPORTANT: Format must be: redis://user:password@host:port
# 
# Valid examples:
#   - redis://default:pass@localhost:6379
#   - rediss://default:pass@upstash-host.upstash.io:6379  (Upstash)
# 
# INVALID (will be rejected):
#   - redis-cli --tls -u redis://...  (command syntax, not URL)
#   - --tls redis://...               (shell flags)
# 
REDIS_URL=redis://default:your-password@localhost:6379

# Redis fallback connection (used if REDIS_URL not provided)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-password

# Redis tuning
REDIS_MAX_BYTES=268435456                   # 256 MB (when to throttle)
UPSTASH_DAILY_REQUEST_LIMIT=10000           # Upstash rate limit
REDIS_OVERFLOW_CAP_PER_QUEUE=200            # Max jobs in overflow buffer
REDIS_WAIT_MS=5000                          # Wait for Redis startup

# ─── OpenAI (REQUIRED for AI features) ────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_RESPONSES_MODEL=gpt-4o-mini          # Model for responses
OPENAI_TIMEOUT=60000                        # Timeout in ms

# ─── Encryption (REQUIRED) ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-256-bit-hex-key-64-characters-long

# ─── Metrics (INTERNAL) ────────────────────────────────────────────────────────
INTERNAL_METRICS_SECRET=omnivyra_internal_metrics_secret_12345

# ─── App Configuration ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.omnivyra.com
DRISHIQ_ENV=production                      # development|staging|production
DRISHIQ_AI_MODE=responses                   # responses|planning|hybrid
Mode=platform                                # platform|standalone|enterprise
ENABLE_AUTO_WORKERS=1                       # Auto-start workers (dev only)
USE_MOCK_PLATFORMS=false                    # Use mock platform adapters
USE_LEGACY_INSIGHTS=false                  # Must remain false for decision intelligence enforcement

# ─── Super Admin Login (REQUIRED for /super-admin) ────────────────────────────
# Set these to enable the /super-admin/login page.
# Choose any username and a strong password.
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=your-strong-password-here

# ─── Social OAuth Credentials ──────────────────────────────────────────────────
# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-secret

# Twitter/X
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-secret

# Facebook
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-secret
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/social/facebook/callback

# Instagram (uses Facebook app)
INSTAGRAM_CLIENT_ID=your-facebook-app-id
INSTAGRAM_CLIENT_SECRET=your-facebook-secret

# YouTube
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-secret

# ─── Anthropic Claude (Optional) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Image Search APIs (Optional) ──────────────────────────────────────────────
# Unsplash (free tier: 50 requests/hour)
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-key

# Pexels (free tier: 200 requests/hour)
# Get from: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-key

# Pixabay (free tier: 100 requests/minute)
# Get from: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-pixabay-key























